{
  "name": "tui-todo-project",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "build": "bun build --compile src/index.tsx --outfile tuitodo",
    "build:mac-arm": "bun build --compile --target=bun-darwin-arm64 src/index.tsx --outfile tuitodo-mac-arm64"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.1.84",
    "@opentui/react": "^0.1.84",
    "react": "^19.2.4"
  }
}
